{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TrailRecord",
  "type": "object",
  "required": [
    "trail_id",
    "trail_name",
    "county_or_region",
    "difficulty",
    "length_miles",
    "elevation_gain_ft",
    "coordinates_or_polyline",
    "source_url",
    "review_text",
    "ingestion_timestamp"
  ],
  "properties": {
    "trail_id": {"type": "string"},
    "trail_name": {"type": "string"},
    "county_or_region": {"type": "string"},
    "difficulty": {"type": "string"},
    "length_miles": {"type": "number"},
    "elevation_gain_ft": {"type": "number"},
    "coordinates_or_polyline": {"type": ["string", "object"]},
    "source_url": {"type": "string"},
    "review_text": {"type": "string"},
    "review_date": {"type": ["string", "null"]},
    "ingestion_timestamp": {"type": "string"}
  }
}
